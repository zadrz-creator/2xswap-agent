# 2xSwap Contracts (Ethereum Mainnet)
X2SWAP_WETH=0x3E77Ad644B4F5FF6AE0B9893bd7bD3CD0136A578
X2SWAP_WBTC=0x8d47d68c92C445c4b583cFfAC6016730CB2059e5
X2POOL=0x2a315fef86916b30905086c85a9cb55e5dcd7ed3
USDC=0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48

# Uniswap V3 Router (for swap paths)
