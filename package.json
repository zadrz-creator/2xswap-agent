{
  "name": "2xswap-autonomous-agent",
  "version": "1.0.0",
  "description": "Autonomous AI trading agent for 2xSwap — leveraged DeFi positions with no liquidation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dashboard": "ts-node src/dashboard.ts",
    "agent": "ts-node src/index.ts --mode agent",
    "monitor": "ts-node src/index.ts --mode monitor",
    "backtest": "ts-node src/backtest/index.ts",
    "backtest:synthetic": "ts-node src/backtest/index.ts --synthetic",
    "backtest:180": "ts-node src/backtest/index.ts --days 180",
    "backtest:365": "ts-node src/backtest/index.ts --days 365",
    "test": "ts-node src/tests/run-all.ts",
    "test:indicators": "ts-node src/tests/indicators.test.ts",
    "test:strategies": "ts-node src/tests/strategies.test.ts",
    "test:backtest": "ts-node src/tests/backtest.test.ts"
  },
  "keywords": ["defi", "2xswap", "trading", "agent", "leverage", "no-liquidation"],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.13.0",
    "dotenv": "^16.4.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "ora": "^5.4.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.11.0"
  }
}
